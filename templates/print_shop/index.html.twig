{% extends 'base.html.twig' %}

{% block title %}Print shop{% endblock %}

{% block body %}
    <section class="coming-soon-page" aria-labelledby="print-shop-title">
        <div class="container">
            <div class="coming-soon-card">
                <p class="hero__tagline">Coming soon</p>

                <h1 id="print-shop-title">
                    Print shop
                </h1>

                <p>
                    Stay tuned. We are preparing a future collaboration with 1Primerie,
                    one of the oldest printing shops in Marseille.
                </p>

                <p>
                    The idea is to help you personalize almost anything you can imagine:
                    mugs, hoodies, jackets, fidgets, stimming tools, weighted blankets,
                    posters, cards and more.
                </p>

                <p>
                    Textures, colors and shapes will be our first priority,
                    with one goal: respecting and cherishing your brain sensitivity.
                </p>

                <p>
                    Aurtistic will not handle payments or orders.
                    This page will simply guide you to the official printing shop website.
                </p>

                <a href="https://1primerie.com/" class="button" target="_blank" rel="noopener noreferrer">
                    Visit 1Primerie
                </a>
            </div>
        </div>
    </section>
{% endblock %}

{% extends 'base.html.twig' %}

{% block title %}{{ lesson.title }}{% endblock %}

{% block body %}
    <section class="lessons-page" aria-labelledby="lesson-title">
        <div class="container">
            <p class="lesson-category">
                {{ lesson.category.title }}
            </p>

            <h1 id="lesson-title">{{ lesson.title }}</h1>

            <p>{{ lesson.topic }}</p>

            <div class="journal-header">
                <h2>Lesson content</h2>

                {% if is_granted('ROLE_ADMIN') %}
                    <a href="{{ path('app_subject_new', {lessonId: lesson.id}) }}" class="button">
                        Add a subject
                    </a>
                {% endif %}
            </div>

            {% if subjects is empty %}
                <p>No content has been added to this lesson yet.</p>
            {% else %}
                <div class="lesson-list">
                    {% for subject in subjects %}
                        <article class="lesson-card">
                            <p class="lesson-category">
                                Part {{ subject.position }}
                            </p>

                            <h2>{{ subject.title }}</h2>

                            <p>{{ subject.description }}</p>
                        </article>
                    {% endfor %}
                </div>
            {% endif %}

            <p>
                <a href="{{ path('app_lesson_index') }}" class="button-secondary">
                    Back to microlearning
                </a>
            </p>
        </div>
    </section>
{% endblock %}
